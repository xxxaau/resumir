{
  "name": "resumir-contingut",
  "version": "2.6.1",
  "description": "Browser extension to summarize web content using Gemini AI",
  "author": "Sergi Xaudiera <sergi@xaudiera.xyz>",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/xxxaau/resumir.git"
  },
  "keywords": [
    "browser-extension",
    "gemini",
    "ai",
    "summarizer",
    "catalan",
    "webextension"
  ],
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "coverage": "c8 --reporter=text --reporter=lcov node scripts/run-tests.mjs",
    "lint": "eslint . --ext .js,.mjs --max-warnings 0 --no-warn-ignored",
    "check": "npm run lint && npm test",
    "build": "node scripts/build.mjs all",
    "build:firefox": "node scripts/build.mjs firefox",
    "build:chromium": "node scripts/build.mjs chromium",
    "release": "node scripts/release.mjs",
    "release:firefox": "node scripts/release.mjs --target firefox",
    "release:chromium": "node scripts/release.mjs --target chromium",
    "dev": "node scripts/set-mode.mjs dev",
    "dev:chromium": "node scripts/dev-chromium.mjs",
    "prod": "node scripts/set-mode.mjs prod",
    "manifests:gen": "node scripts/merge-manifest.mjs firefox manifest.json && node scripts/merge-manifest.mjs chromium manifest.chromium.json",
    "version:sync": "node scripts/bump-version.mjs",
    "version": "node scripts/bump-version.mjs && node scripts/update-changelog-html.mjs && git add manifest.base.json manifest.json manifest.chromium.json options/settings.html docs/CHANGELOG.md",
    "prerelease": "node scripts/pre-release-check.mjs",
    "prepare-release": "node scripts/prepare-release.mjs",
    "vendor:verify": "node scripts/verify-vendor.mjs",
    "models:check": "node scripts/update-models-check.mjs",
    "models:sync": "node scripts/update-models-sync.mjs",
    "smoke:connectors": "node scripts/connector-smoke.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.60.0",
    "c8": "^11.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^29.0.1",
    "pdfkit": "^0.18.0"
  }
}
