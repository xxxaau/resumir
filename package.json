{
  "name": "resumir-contingut",
  "version": "2.0.1",
  "description": "Browser extension to summarize web content using Gemini AI",
  "private": true,
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint sidebar/ options/ *.js --max-warnings 50",
    "build": "pwsh ./build.ps1 -Target all",
    "build:firefox": "pwsh ./build.ps1 -Target firefox",
    "build:chromium": "pwsh ./build.ps1 -Target chromium",
    "dev": "pwsh ./set_dev_mode.ps1 dev",
    "prod": "pwsh ./set_dev_mode.ps1 prod",
    "version:sync": "node scripts/bump-version.mjs",
    "postversion": "node scripts/bump-version.mjs && git add manifest.json manifest.chromium.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0"
  }
}
