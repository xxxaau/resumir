{
  "name": "resumir-contingut",
  "version": "2.2.2",
  "description": "Browser extension to summarize web content using Gemini AI",
  "private": true,
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint . --ext .js,.mjs --max-warnings 50 --no-warn-ignored",
    "check": "npm run lint && npm test",
    "build": "node scripts/pwsh-runner.mjs ./build.ps1 -Target all",
    "build:firefox": "node scripts/pwsh-runner.mjs ./build.ps1 -Target firefox",
    "build:chromium": "node scripts/pwsh-runner.mjs ./build.ps1 -Target chromium",
    "release": "node scripts/pwsh-runner.mjs ./release.ps1 -Target all",
    "release:firefox": "node scripts/pwsh-runner.mjs ./release.ps1 -Target firefox",
    "release:chromium": "node scripts/pwsh-runner.mjs ./release.ps1 -Target chromium",
    "dev": "node scripts/pwsh-runner.mjs ./set_dev_mode.ps1 dev",
    "prod": "node scripts/pwsh-runner.mjs ./set_dev_mode.ps1 prod",
    "manifests:gen": "node scripts/merge-manifest.mjs firefox manifest.json && node scripts/merge-manifest.mjs chromium manifest.chromium.json",
    "version:sync": "node scripts/bump-version.mjs",
    "postversion": "node scripts/bump-version.mjs && node scripts/update-changelog-html.mjs && git add manifest.base.json manifest.json manifest.chromium.json options/settings.html CHANGELOG.md",
    "prerelease": "node scripts/pre-release-check.mjs",
    "vendor:update": "node scripts/copy-vendor.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "defuddle": "^0.14.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "jsdom": "^29.0.1"
  }
}
