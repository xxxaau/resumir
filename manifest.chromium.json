{
    "manifest_version": 3,
    "name": "Resumir contingut",
    "version": "2.2.3",
    "author": "Sergi Xaudiera",
    "homepage_url": "https://github.com/xxxaau/extensio-resumir-contingut",
    "description": "Resumeix text seleccionat amb Gemini.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs",
        "contextMenus",
        "sidePanel"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": "Obre Resumir contingut",
        "default_icon": "icons/icon-96.png"
    },
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "64": "icons/icon-64.png",
        "96": "icons/icon-96.png",
        "128": "icons/icon-128.png"
    },
    "options_ui": {
        "page": "options/settings.html",
        "open_in_tab": true
    },
    "side_panel": {
        "default_path": "sidebar/sidebar.html"
    },
    "background": {
        "service_worker": "background.bundle.js",
        "type": "module"
    }
}
